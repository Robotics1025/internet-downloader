{
  "manifest_version": 3,
  "name": "DownloadMgr Bridge",
  "version": "0.2.0",
  "description": "Send the current page (or any video / link) to your local DownloadMgr desktop app with one click.",
  "permissions": ["activeTab", "contextMenus", "storage", "notifications"],
  "host_permissions": [
    "http://127.0.0.1:*/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Send to DownloadMgr"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
